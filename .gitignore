# Pycharm
.idea

# Python venv (Linux-only, recreated by bench inside container)
development/frappe-bench/env/

# Node modules (contain Linux symlinks, recreated by yarn/npm inside container)
**/node_modules/

# Sites assets symlinks (recreated by bench build inside container)
development/frappe-bench/sites/assets/frappe
development/frappe-bench/sites/assets/erpnext
development/frappe-bench/sites/assets/education
development/frappe-bench/sites/assets/hrms
development/frappe-bench/sites/assets/university_erp

# Python
*.pyc
__pycache__

# Misc
*.code-workspace

# Logs (Frappe/bench runtime output — regenerated)
development/frappe-bench/logs/
development/frappe-bench/sites/*/logs/
development/logs/
*.log
*.log.[0-9]*

# Frappe site runtime state (regenerated)
development/frappe-bench/sites/*/indexes/
development/frappe-bench/sites/*/touched_tables.json

# Frappe site backups (contain DB dumps — never commit)
development/frappe-bench/sites/*/private/backups/

# Vite build output (regenerated by `npm run build`)
development/frappe-bench/apps/university_erp/university_erp/public/portal/assets/
development/frappe-bench/apps/university_erp/university_erp/public/portal/.vite/
development/frappe-bench/apps/university_erp/university_erp/public/student-portal-spa/assets/
development/frappe-bench/apps/university_erp/university_erp/public/student-portal-spa/.vite/

# GSD working cache
.gsd-cache/
