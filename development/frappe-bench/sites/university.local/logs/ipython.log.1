2026-03-16 18:06:36,107 INFO ipython broken = []
2026-03-16 18:06:36,109 INFO ipython for f in sorted(glob.glob("*/doctype/*/*.json") + glob.glob("university_erp/doctype/*/*.json")):
    if "__pycache__" in f:
        continue
    try:
        with open(f) as fh:
            data = json.load(fh)
    except:
        continue
    if not isinstance(data.get("fields"), list):
        continue
    dt_name = data.get("name", "?")
