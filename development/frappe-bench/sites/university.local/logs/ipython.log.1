2026-03-16 12:49:07,825 INFO ipython import frappe
2026-03-16 12:49:07,826 INFO ipython frappe.flags.ignore_permissions = True
2026-03-16 12:49:07,828 INFO ipython def safe_delete_all(doctype):
    """Delete all records of a doctype if it exists"""
    if not frappe.db.exists("DocType", doctype):
        print(f"  SKIP {doctype} (DocType doesn't exist)")
        return 0
    records = frappe.get_all(doctype, pluck="name")
    count = len(records)
    for name in records:
        try:
            frappe.delete_doc(doctype, name, force=True, ignore_permissions=True)
        except Exception as e:
            # Try direct DB delete as fallback
            try:
                frappe.db.delete(doctype, {"name": name})
            except:
                print(f"  WARN: Could not delete {doctype}/{name}: {e}")
    if count:
        print(f"  Deleted {count} {doctype} records")
    else:
        print(f"  No {doctype} records found")
    return count
2026-03-16 12:49:07,829 INFO ipython def safe_delete_filtered(doctype, filters):
    """Delete records matching filters"""
    if not frappe.db.exists("DocType", doctype):
        print(f"  SKIP {doctype} (DocType doesn't exist)")
        return 0
    records = frappe.get_all(doctype, filters=filters, pluck="name")
    count = len(records)
    for name in records:
        try:
            frappe.delete_doc(doctype, name, force=True, ignore_permissions=True)
        except Exception as e:
            try:
                frappe.db.delete(doctype, {"name": name})
            except:
                print(f"  WARN: Could not delete {doctype}/{name}: {e}")
    if count:
        print(f"  Deleted {count} {doctype} records")
    else:
        print(f"  No {doctype} records matching {filters}")
    return count
