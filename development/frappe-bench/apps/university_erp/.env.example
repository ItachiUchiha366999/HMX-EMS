# University ERP Environment Configuration
# Copy this file to .env and update the values

# ======================
# Site Configuration
# ======================
SITE_NAME=university.local
HTTP_PORT=80
HTTPS_PORT=443

# ======================
# Database Configuration
# ======================
MYSQL_ROOT_PASSWORD=your_secure_root_password
MYSQL_DATABASE=university_erp
MYSQL_USER=frappe
MYSQL_PASSWORD=your_secure_password

# ======================
# Redis Configuration
# ======================
REDIS_CACHE=redis://redis-cache:6379
REDIS_QUEUE=redis://redis-queue:6379

# ======================
# Email Configuration
# ======================
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=1
MAIL_LOGIN=notifications@university.edu
MAIL_PASSWORD=your_email_password

# ======================
# Payment Gateway
# ======================
# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# PayU (optional)
PAYU_MERCHANT_KEY=
PAYU_SALT=

# ======================
# Push Notifications
# ======================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
PUSH_EMAIL=admin@university.edu

# ======================
# External Integrations
# ======================
# DigiLocker (optional)
DIGILOCKER_CLIENT_ID=
DIGILOCKER_CLIENT_SECRET=

# ======================
# Backup Configuration
# ======================
BACKUP_DIR=/var/backups/university_erp
RETENTION_DAYS=30
S3_BUCKET=

# ======================
# Monitoring
# ======================
SENTRY_DSN=
SLACK_WEBHOOK_URL=

# ======================
# Deployment
# ======================
GIT_BRANCH=main
ENVIRONMENT=production
