# Docker ignore file for University ERP

# Git
.git
.gitignore
.gitattributes

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
tests/
*.test.py
*.spec.js

# Documentation (built separately)
docs/
*.md
!README.md

# Environment
.env
.env.*
*.local

# Logs
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp
*.temp

# OS files
.DS_Store
Thumbs.db

# Coverage
coverage/
.nyc_output/

# Build artifacts (rebuilt in container)
*.bundle.js
*.bundle.css
