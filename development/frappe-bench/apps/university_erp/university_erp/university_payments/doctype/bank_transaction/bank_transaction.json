{
  "doctype": "DocType",
  "name": "Bank Transaction",
  "module": "University Payments",
  "naming_rule": "Expression",
  "autoname": "BTX-.YYYY.-.#####",
  "engine": "InnoDB",
  "field_order": [
    "bank_account",
    "date",
    "description",
    "reference_number",
    "column_break_1",
    "deposit",
    "withdrawal",
    "closing_balance",
    "status_section",
    "status",
    "matched_by",
    "column_break_2",
    "payment_entry",
    "payment_order"
  ],
  "fields": [
    {
      "fieldname": "bank_account",
      "fieldtype": "Link",
      "label": "Bank Account",
      "options": "Bank Account",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "date",
      "fieldtype": "Date",
      "label": "Date",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "description",
      "fieldtype": "Data",
      "label": "Description",
      "in_list_view": 1
    },
    {
      "fieldname": "reference_number",
      "fieldtype": "Data",
      "label": "Reference Number"
    },
    {
      "fieldname": "column_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "deposit",
      "fieldtype": "Currency",
      "label": "Deposit",
      "in_list_view": 1
    },
    {
      "fieldname": "withdrawal",
      "fieldtype": "Currency",
      "label": "Withdrawal",
      "in_list_view": 1
    },
    {
      "fieldname": "closing_balance",
      "fieldtype": "Currency",
      "label": "Closing Balance"
    },
    {
      "fieldname": "status_section",
      "fieldtype": "Section Break",
      "label": "Reconciliation Status"
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Pending\nReconciled\nUnreconciled",
      "default": "Pending",
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "matched_by",
      "fieldtype": "Select",
      "label": "Matched By",
      "options": "\nAuto\nManual",
      "read_only": 1
    },
    {
      "fieldname": "column_break_2",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "payment_entry",
      "fieldtype": "Link",
      "label": "Payment Entry",
      "options": "Payment Entry",
      "read_only": 1
    },
    {
      "fieldname": "payment_order",
      "fieldtype": "Link",
      "label": "Payment Order",
      "options": "Payment Order",
      "read_only": 1
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "report": 1,
      "share": 1
    },
    {
      "role": "University Admin",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "report": 1,
      "share": 1
    },
    {
      "role": "University Finance",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "report": 1,
      "share": 1
    }
  ],
  "track_changes": 1,
  "sort_field": "date",
  "sort_order": "DESC",
  "modified_by": "Administrator",
  "owner": "Administrator"
}