{
  "doctype": "DocType",
  "name": "Payment Order",
  "module": "University Payments",
  "naming_rule": "Expression",
  "autoname": "PO-.YYYY.-.#####",
  "engine": "InnoDB",
  "field_order": [
    "reference_doctype",
    "reference_name",
    "student",
    "student_name",
    "column_break_1",
    "payment_gateway",
    "status",
    "creation_date",
    "payment_section",
    "gateway_order_id",
    "gateway_payment_id",
    "amount",
    "currency",
    "column_break_2",
    "payment_date",
    "payment_entry",
    "mode_of_payment",
    "failure_section",
    "failure_reason",
    "retry_count",
    "refund_section",
    "refund_id",
    "refund_amount",
    "refund_date",
    "refund_reason"
  ],
  "fields": [
    {
      "fieldname": "reference_doctype",
      "fieldtype": "Link",
      "label": "Reference Type",
      "options": "DocType",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "reference_name",
      "fieldtype": "Dynamic Link",
      "label": "Reference Name",
      "options": "reference_doctype",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "student",
      "fieldtype": "Link",
      "label": "Student",
      "options": "Student",
      "in_standard_filter": 1
    },
    {
      "fieldname": "student_name",
      "fieldtype": "Data",
      "label": "Student Name",
      "fetch_from": "student.student_name",
      "read_only": 1
    },
    {
      "fieldname": "column_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "payment_gateway",
      "fieldtype": "Select",
      "label": "Payment Gateway",
      "options": "\nRazorpay\nPayU\nPaytm\nCashfree",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Created\nPending\nCompleted\nFailed\nRefunded\nCancelled",
      "default": "Created",
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "creation_date",
      "fieldtype": "Datetime",
      "label": "Creation Date",
      "default": "Now",
      "read_only": 1
    },
    {
      "fieldname": "payment_section",
      "fieldtype": "Section Break",
      "label": "Payment Details"
    },
    {
      "fieldname": "gateway_order_id",
      "fieldtype": "Data",
      "label": "Gateway Order ID",
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "gateway_payment_id",
      "fieldtype": "Data",
      "label": "Gateway Payment ID",
      "read_only": 1
    },
    {
      "fieldname": "amount",
      "fieldtype": "Currency",
      "label": "Amount",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "currency",
      "fieldtype": "Link",
      "label": "Currency",
      "options": "Currency",
      "default": "INR"
    },
    {
      "fieldname": "column_break_2",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "payment_date",
      "fieldtype": "Datetime",
      "label": "Payment Date",
      "read_only": 1
    },
    {
      "fieldname": "payment_entry",
      "fieldtype": "Link",
      "label": "Payment Entry",
      "options": "Payment Entry",
      "read_only": 1
    },
    {
      "fieldname": "mode_of_payment",
      "fieldtype": "Link",
      "label": "Mode of Payment",
      "options": "Mode of Payment",
      "read_only": 1
    },
    {
      "fieldname": "failure_section",
      "fieldtype": "Section Break",
      "label": "Failure Details",
      "depends_on": "eval:doc.status=='Failed'",
      "collapsible": 1
    },
    {
      "fieldname": "failure_reason",
      "fieldtype": "Small Text",
      "label": "Failure Reason",
      "read_only": 1
    },
    {
      "fieldname": "retry_count",
      "fieldtype": "Int",
      "label": "Retry Count",
      "default": "0",
      "read_only": 1
    },
    {
      "fieldname": "refund_section",
      "fieldtype": "Section Break",
      "label": "Refund Details",
      "depends_on": "eval:doc.status=='Refunded'",
      "collapsible": 1
    },
    {
      "fieldname": "refund_id",
      "fieldtype": "Data",
      "label": "Refund ID",
      "read_only": 1
    },
    {
      "fieldname": "refund_amount",
      "fieldtype": "Currency",
      "label": "Refund Amount",
      "read_only": 1
    },
    {
      "fieldname": "refund_date",
      "fieldtype": "Datetime",
      "label": "Refund Date",
      "read_only": 1
    },
    {
      "fieldname": "refund_reason",
      "fieldtype": "Small Text",
      "label": "Refund Reason",
      "read_only": 1
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "report": 1,
      "share": 1
    },
    {
      "role": "University Admin",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "report": 1,
      "share": 1
    },
    {
      "role": "University Finance",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "report": 1,
      "share": 1
    }
  ],
  "track_changes": 1,
  "sort_field": "creation",
  "sort_order": "DESC",
  "modified_by": "Administrator",
  "owner": "Administrator"
}