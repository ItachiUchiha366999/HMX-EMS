{
  "doctype": "DocType",
  "name": "Internal Assessment Score",
  "module": "University Examinations",
  "istable": 1,
  "editable_grid": 1,
  "fields": [
    {
      "fieldname": "student",
      "fieldtype": "Link",
      "label": "Student",
      "options": "Student",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "student_name",
      "fieldtype": "Data",
      "label": "Student Name",
      "fetch_from": "student.student_name",
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "roll_number",
      "fieldtype": "Data",
      "label": "Roll Number",
      "fetch_from": "student.roll_number",
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "criteria_scores",
      "fieldtype": "JSON",
      "label": "Criteria Scores",
      "description": "JSON object with criteria-wise scores"
    },
    {
      "fieldname": "total_marks",
      "fieldtype": "Float",
      "label": "Total Marks",
      "in_list_view": 1
    },
    {
      "fieldname": "percentage",
      "fieldtype": "Percent",
      "label": "Percentage",
      "read_only": 1
    },
    {
      "fieldname": "grade",
      "fieldtype": "Data",
      "label": "Grade",
      "in_list_view": 1
    },
    {
      "fieldname": "attendance_percentage",
      "fieldtype": "Percent",
      "label": "Attendance %",
      "read_only": 1
    },
    {
      "fieldname": "remarks",
      "fieldtype": "Small Text",
      "label": "Remarks"
    },
    {
      "fieldname": "evaluated_by",
      "fieldtype": "Link",
      "label": "Evaluated By",
      "options": "Instructor"
    },
    {
      "fieldname": "evaluation_date",
      "fieldtype": "Date",
      "label": "Evaluation Date"
    }
  ],
  "track_changes": 1,
  "engine": "InnoDB"
}
