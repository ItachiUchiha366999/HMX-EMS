      "create": 0,
      "delete": 0,
      "email": 1,
      "export": 1,
      "print": 1,
      "report": 1,
      "share": 0
    }
  ],
  "sort_field": "tag_name",
  "sort_order": "ASC",
  "title_field": "tag_name",
  "search_fields": "tag_name,description",
