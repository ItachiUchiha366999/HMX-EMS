      "email": 1,
      "export": 1,
      "print": 1,
      "report": 1,
      "share": 1
    },
    {
      "role": "University Admin",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "report": 1,
      "share": 1
    },
    {
      "role": "University Exam Cell",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "report": 1,
      "share": 1
    },
    {
      "role": "University Faculty",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 0,
      "email": 1,
      "export": 1,
      "print": 1,
