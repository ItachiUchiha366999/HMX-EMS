{
  "doctype": "DocType",
  "name": "Internal Assessment",
  "module": "University Examinations",
  "naming_rule": "Expression",
  "autoname": "IA-.YYYY.-.#####",
  "is_submittable": 1,
  "fields": [
    {
      "fieldname": "assessment_name",
      "fieldtype": "Data",
      "label": "Assessment Name",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "assessment_type",
      "fieldtype": "Select",
      "label": "Assessment Type",
      "options": "\nAssignment\nQuiz\nMid-Term\nProject\nPresentation\nLab Work\nClass Test\nOther",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "column_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "academic_year",
      "fieldtype": "Link",
      "label": "Academic Year",
      "options": "Academic Year",
      "reqd": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "academic_term",
      "fieldtype": "Link",
      "label": "Academic Term",
      "options": "Academic Term",
      "reqd": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "section_break_course",
      "fieldtype": "Section Break",
      "label": "Course Details"
    },
    {
      "fieldname": "course",
      "fieldtype": "Link",
      "label": "Course",
      "options": "Course",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "course_name",
      "fieldtype": "Data",
      "label": "Course Name",
      "fetch_from": "course.course_name",
      "read_only": 1
    },
    {
      "fieldname": "column_break_course",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "program",
      "fieldtype": "Link",
      "label": "Program",
      "options": "Program"
    },
    {
      "fieldname": "student_group",
      "fieldtype": "Link",
      "label": "Student Group",
      "options": "Student Group"
    },
    {
      "fieldname": "section_break_schedule",
      "fieldtype": "Section Break",
      "label": "Schedule"
    },
    {
      "fieldname": "assessment_date",
      "fieldtype": "Date",
      "label": "Assessment Date",
      "reqd": 1
    },
    {
      "fieldname": "start_time",
      "fieldtype": "Time",
      "label": "Start Time"
    },
    {
      "fieldname": "end_time",
      "fieldtype": "Time",
      "label": "End Time"
    },
    {
      "fieldname": "column_break_schedule",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "submission_deadline",
      "fieldtype": "Datetime",
      "label": "Submission Deadline"
    },
    {
      "fieldname": "late_submission_allowed",
      "fieldtype": "Check",
      "label": "Allow Late Submission"
    },
    {
      "fieldname": "late_penalty_percentage",
      "fieldtype": "Percent",
      "label": "Late Penalty %",
      "depends_on": "late_submission_allowed"
    },
    {
      "fieldname": "section_break_marks",
      "fieldtype": "Section Break",
      "label": "Marks Configuration"
    },
    {
      "fieldname": "maximum_marks",
      "fieldtype": "Float",
      "label": "Maximum Marks",
      "reqd": 1
    },
    {
      "fieldname": "passing_marks",
      "fieldtype": "Float",
      "label": "Passing Marks"
    },
    {
      "fieldname": "weightage",
      "fieldtype": "Percent",
      "label": "Weightage in Final Grade"
    },
    {
      "fieldname": "column_break_marks",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "grading_scale",
      "fieldtype": "Link",
      "label": "Grading Scale",
      "options": "Grading Scale"
    },
    {
      "fieldname": "rubric",
      "fieldtype": "Link",
      "label": "Assessment Rubric",
      "options": "Assessment Rubric"
    },
    {
      "fieldname": "section_break_criteria",
      "fieldtype": "Section Break",
      "label": "Assessment Criteria"
    },
    {
      "fieldname": "criteria",
      "fieldtype": "Table",
      "label": "Criteria",
      "options": "Assessment Criteria Item"
    },
    {
      "fieldname": "section_break_co",
      "fieldtype": "Section Break",
      "label": "Course Outcome Mapping"
    },
    {
      "fieldname": "co_mapping",
      "fieldtype": "Table",
      "label": "CO Mapping",
      "options": "Assessment CO Link"
    },
    {
      "fieldname": "section_break_scores",
      "fieldtype": "Section Break",
      "label": "Student Scores"
    },
    {
      "fieldname": "scores",
      "fieldtype": "Table",
      "label": "Scores",
      "options": "Internal Assessment Score"
    },
    {
      "fieldname": "section_break_summary",
      "fieldtype": "Section Break",
      "label": "Summary"
    },
    {
      "fieldname": "total_students",
      "fieldtype": "Int",
      "label": "Total Students",
      "read_only": 1
    },
    {
      "fieldname": "evaluated_count",
      "fieldtype": "Int",
      "label": "Evaluated",
      "read_only": 1
    },
    {
      "fieldname": "passed_count",
      "fieldtype": "Int",
      "label": "Passed",
      "read_only": 1
    },
    {
      "fieldname": "column_break_summary",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "average_marks",
      "fieldtype": "Float",
      "label": "Average Marks",
      "read_only": 1
    },
    {
      "fieldname": "highest_marks",
      "fieldtype": "Float",
      "label": "Highest Marks",
      "read_only": 1
    },
    {
      "fieldname": "lowest_marks",
      "fieldtype": "Float",
      "label": "Lowest Marks",
      "read_only": 1
    },
    {
      "fieldname": "section_break_faculty",
      "fieldtype": "Section Break",
      "label": "Faculty Details"
    },
    {
      "fieldname": "instructor",
      "fieldtype": "Link",
      "label": "Instructor",
      "options": "Instructor"
    },
    {
      "fieldname": "evaluator",
      "fieldtype": "Link",
      "label": "Evaluator",
      "options": "Instructor"
    },
    {
      "fieldname": "column_break_faculty",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Draft\nScheduled\nIn Progress\nEvaluation Pending\nCompleted\nCancelled",
      "default": "Draft",
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "section_break_instructions",
      "fieldtype": "Section Break",
      "label": "Instructions & Attachments"
    },
    {
      "fieldname": "instructions",
      "fieldtype": "Text Editor",
      "label": "Instructions"
    },
    {
      "fieldname": "attachment",
      "fieldtype": "Attach",
      "label": "Question Paper/Assignment"
    },
    {
      "fieldname": "reference_material",
      "fieldtype": "Attach",
      "label": "Reference Material"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "report": 1,
      "share": 1
    },
    {
      "role": "University Admin",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "report": 1,
      "share": 1
    },
    {
      "role": "University Exam Cell",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "report": 1,
      "share": 1
    },
    {
      "role": "University Faculty",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 0,
      "email": 1,
      "export": 1,
      "print": 1,
      "report": 1,
      "share": 1
    },
    {
