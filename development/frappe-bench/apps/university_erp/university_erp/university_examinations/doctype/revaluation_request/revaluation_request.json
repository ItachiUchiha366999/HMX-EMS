{
  "doctype": "DocType",
  "name": "Revaluation Request",
  "module": "University Examinations",
  "naming_rule": "Expression",
  "autoname": "RR-.YYYY.-.#####",
  "is_submittable": 1,
  "fields": [
    {
      "fieldname": "answer_sheet",
      "fieldtype": "Link",
      "label": "Answer Sheet",
      "options": "Answer Sheet",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "student",
      "fieldtype": "Link",
      "label": "Student",
      "options": "Student",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "student_name",
      "fieldtype": "Data",
      "label": "Student Name",
      "fetch_from": "student.student_name",
      "read_only": 1
    },
    {
      "fieldname": "column_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "examination",
      "fieldtype": "Link",
      "label": "Examination",
      "options": "Exam Schedule",
      "fetch_from": "answer_sheet.examination",
      "read_only": 1
    },
    {
      "fieldname": "course",
      "fieldtype": "Link",
      "label": "Course",
      "options": "Course",
      "fetch_from": "answer_sheet.course",
      "read_only": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "section_break_reason",
      "fieldtype": "Section Break",
      "label": "Reason"
    },
    {
      "fieldname": "reason",
      "fieldtype": "Text",
      "label": "Reason for Revaluation",
      "reqd": 1
    },
    {
      "fieldname": "section_break_marks",
      "fieldtype": "Section Break",
      "label": "Marks"
    },
    {
      "fieldname": "original_marks",
      "fieldtype": "Float",
      "label": "Original Marks",
      "read_only": 1
    },
    {
      "fieldname": "revaluation_marks",
      "fieldtype": "Float",
      "label": "Revaluation Marks"
    },
    {
      "fieldname": "marks_difference",
      "fieldtype": "Float",
      "label": "Marks Difference",
      "read_only": 1
    },
    {
      "fieldname": "column_break_2",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "assigned_evaluator",
      "fieldtype": "Link",
      "label": "Assigned Evaluator",
      "options": "Instructor"
    },
    {
      "fieldname": "evaluation_date",
      "fieldtype": "Datetime",
      "label": "Evaluation Date"
    },
    {
      "fieldname": "section_break_fee",
      "fieldtype": "Section Break",
      "label": "Fee"
    },
    {
      "fieldname": "fee_paid",
      "fieldtype": "Check",
      "label": "Fee Paid"
    },
    {
      "fieldname": "fee_amount",
      "fieldtype": "Currency",
      "label": "Fee Amount"
    },
    {
      "fieldname": "payment_reference",
      "fieldtype": "Data",
      "label": "Payment Reference"
    },
    {
      "fieldname": "section_break_decision",
      "fieldtype": "Section Break",
      "label": "Decision"
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Draft\nPending\nIn Progress\nCompleted\nRejected",
      "default": "Draft",
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "decision_date",
      "fieldtype": "Datetime",
      "label": "Decision Date"
    },
    {
      "fieldname": "decision_remarks",
      "fieldtype": "Text",
      "label": "Decision Remarks"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "report": 1,
      "share": 1
    },
    {
      "role": "University Admin",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "report": 1,
      "share": 1
    },
    {
      "role": "University Exam Cell",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "report": 1,
      "share": 1
    },
    {
      "role": "University Faculty",
      "read": 1,
      "write": 0,
      "create": 0,
      "delete": 0,
      "email": 1,
      "export": 1,
      "print": 1,
      "report": 1,
      "share": 0
    },
    {
      "role": "University Student",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 0,
      "email": 1,
      "export": 1,
      "print": 1,
      "report": 1,
      "share": 1,
      "if_owner": 1
    }
  ],
  "sort_field": "modified",
  "sort_order": "DESC",
  "search_fields": "student,course,status",
  "track_changes": 1,
  "engine": "InnoDB"
}