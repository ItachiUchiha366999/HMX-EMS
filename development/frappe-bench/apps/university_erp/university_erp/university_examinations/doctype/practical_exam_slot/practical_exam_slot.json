{
  "doctype": "DocType",
  "name": "Practical Exam Slot",
  "module": "University Examinations",
  "istable": 1,
  "editable_grid": 1,
  "fields": [
    {
      "fieldname": "slot_date",
      "fieldtype": "Date",
      "label": "Date",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "start_time",
      "fieldtype": "Time",
      "label": "Start Time",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "end_time",
      "fieldtype": "Time",
      "label": "End Time",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "batch",
      "fieldtype": "Data",
      "label": "Batch/Group",
      "in_list_view": 1
    },
    {
      "fieldname": "room",
      "fieldtype": "Link",
      "label": "Room/Lab",
      "options": "Room",
      "in_list_view": 1
    },
    {
      "fieldname": "max_students",
      "fieldtype": "Int",
      "label": "Max Students",
      "default": "20"
    },
    {
      "fieldname": "enrolled_students",
      "fieldtype": "Int",
      "label": "Enrolled",
      "read_only": 1
    },
    {
      "fieldname": "assigned_examiner",
      "fieldtype": "Link",
      "label": "Assigned Examiner",
      "options": "Instructor"
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "\nScheduled\nIn Progress\nCompleted\nCancelled",
      "default": "Scheduled"
    }
  ],
  "track_changes": 1,
  "engine": "InnoDB"
}
