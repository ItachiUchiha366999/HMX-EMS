  "options": "\nTeaching Staff\nNon-Teaching Staff\nAdministrative Staff\nContract Faculty\nVisiting Faculty",
  "insert_after": "custom_faculty_profile"
 },
 {
  "doctype": "Custom Field",
  "dt": "Employee",
  "name": "Employee-custom_column_break_faculty",
  "fieldname": "custom_column_break_faculty",
  "fieldtype": "Column Break",
  "insert_after": "custom_employee_category"
 },
 {
  "doctype": "Custom Field",
  "dt": "Employee",
  "name": "Employee-custom_faculty_type",
  "fieldname": "custom_faculty_type",
  "fieldtype": "Select",
  "label": "Faculty Type",
  "options": "\nPermanent\nTemporary\nAdhoc\nGuest",
  "insert_after": "custom_column_break_faculty"
 },
 {
  "doctype": "Custom Field",
  "dt": "Employee",
  "name": "Employee-custom_current_workload",
  "fieldname": "custom_current_workload",
  "fieldtype": "Float",
