  "label": "Qualifications",
  "options": "Employee Qualification",
  "insert_after": "custom_qualification_section"
 },
 {
  "doctype": "Custom Field",
  "dt": "Employee",
  "name": "Employee-custom_highest_qualification",
  "fieldname": "custom_highest_qualification",
