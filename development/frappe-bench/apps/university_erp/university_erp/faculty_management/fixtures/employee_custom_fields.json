[
 {
  "doctype": "Custom Field",
  "dt": "Employee",
  "name": "Employee-custom_faculty_section",
  "fieldname": "custom_faculty_section",
  "fieldtype": "Section Break",
  "label": "University Faculty Details",
  "insert_after": "personal_details"
 },
 {
  "doctype": "Custom Field",
  "dt": "Employee",
  "name": "Employee-custom_is_faculty",
  "fieldname": "custom_is_faculty",
  "fieldtype": "Check",
  "label": "Is Faculty",
  "insert_after": "custom_faculty_section",
  "default": "0"
 },
 {
  "doctype": "Custom Field",
  "dt": "Employee",
  "name": "Employee-custom_faculty_profile",
  "fieldname": "custom_faculty_profile",
  "fieldtype": "Link",
  "label": "Faculty Profile",
  "options": "Faculty Profile",
  "insert_after": "custom_is_faculty",
  "read_only": 1
 },
 {
  "doctype": "Custom Field",
  "dt": "Employee",
  "name": "Employee-custom_employee_category",
  "fieldname": "custom_employee_category",
  "fieldtype": "Select",
